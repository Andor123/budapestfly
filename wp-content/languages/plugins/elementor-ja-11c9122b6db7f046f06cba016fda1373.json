6f4\u306f\u9069\u7528\u3055\u308c\u306a\u304f\u306a\u308a\u307e\u3059\u3002\u7d9a\u884c\u3057\u307e\u3059\u304b ?"],"Detach from Component?":["\u30b3\u30f3\u30dd\u30fc\u30cd\u30f3\u30c8\u304b\u3089\u5207\u308a\u96e2\u3057\u307e\u3059\u304b ?"],"Create new Components":["\u65b0\u3057\u3044\u30b3\u30f3\u30dd\u30fc\u30cd\u30f3\u30c8\u3092\u4f5c\u6210"],"Creating new components requires an active Pro subscription.":["\u65b0\u3057\u3044\u30b3\u30f3\u30dd\u30fc\u30cd\u30f3\u30c8\u3092\u4f5c\u6210\u3059\u308b\u306b\u306f\u3001\u6709\u52b9\u306a Pro \u30b5\u30d6\u30b9\u30af\u30ea\u30d7\u30b7\u30e7\u30f3\u304c\u5fc5\u8981\u3067\u3059\u3002"],"Create new components":["\u65b0\u3057\u3044\u30b3\u30f3\u30dd\u30fc\u30cd\u30f3\u30c8\u3092\u4f5c\u6210"],"To create components, update Elementor Pro to the latest version.":["\u30b3\u30f3\u30dd\u30fc\u30cd\u30f3\u30c8\u3092\u4f5c\u6210\u3059\u308b\u306b\u306f\u3001Elementor Pro \u3092\u6700\u65b0\u30d0\u30fc\u30b8\u30e7\u30f3\u306b\u30a2\u30c3\u30d7\u30c7\u30fc\u30c8\u3057\u3066\u304f\u3060\u3055\u3044\u3002"],"Create design elements that sync across your entire site.":["\u30b5\u30a4\u30c8\u5168\u4f53\u3067\u540c\u671f\u3055\u308c\u308b\u30c7\u30b6\u30a4\u30f3\u8981\u7d20\u3092\u4f5c\u6210\u3002"],"Create Reusable Components":["\u518d\u5229\u7528\u53ef\u80fd\u306a\u30b3\u30f3\u30dd\u30fc\u30cd\u30f3\u30c8\u306e\u4f5c\u6210"],"To create new components, update Elementor Pro to the latest version.":["\u65b0\u3057\u3044\u30b3\u30f3\u30dd\u30fc\u30cd\u30f3\u30c8\u3092\u4f5c\u6210\u3059\u308b\u306b\u306f\u3001Elementor Pro \u3092\u6700\u65b0\u30d0\u30fc\u30b8\u30e7\u30f3\u306b\u66f4\u65b0\u3057\u3066\u304f\u3060\u3055\u3044\u3002"],"Edit component":["\u30b3\u30f3\u30dd\u30fc\u30cd\u30f3\u30c8\u3092\u7de8\u96c6"],"No properties yet":["\u307e\u3060\u30d7\u30ed\u30d1\u30c6\u30a3\u306f\u3042\u308a\u307e\u305b\u3093"],"With your current role, you cannot edit this component. Contact an administrator to add properties.":["\u73fe\u5728\u306e\u6a29\u9650\u30b0\u30eb\u30fc\u30d7\u3067\u306f\u3001\u3053\u306e\u30b3\u30f3\u30dd\u30fc\u30cd\u30f3\u30c8\u3092\u7de8\u96c6\u3067\u304d\u307e\u305b\u3093\u3002\u30d7\u30ed\u30d1\u30c6\u30a3\u3092\u8ffd\u52a0\u3059\u308b\u306b\u306f\u3001\u7ba1\u7406\u8005\u306b\u9023\u7d61\u3057\u3066\u304f\u3060\u3055\u3044\u3002"],"Edit the component to add properties, manage them or update the design across all instances.":["\u30b3\u30f3\u30dd\u30fc\u30cd\u30f3\u30c8\u3092\u7de8\u96c6\u3057\u3066\u3001\u30d7\u30ed\u30d1\u30c6\u30a3\u3092\u8ffd\u52a0\u3001\u7ba1\u7406\u3001\u307e\u305f\u306f\u3059\u3079\u3066\u306e\u30a4\u30f3\u30b9\u30bf\u30f3\u30b9\u306b\u308f\u305f\u3063\u3066\u30c7\u30b6\u30a4\u30f3\u3092\u66f4\u65b0\u3057\u307e\u3059\u3002"],"Right-click any div-block or flexbox on your canvas or structure and select \"Create component\"":["\u30ad\u30e3\u30f3\u30d0\u30b9\u307e\u305f\u306f\u69cb\u9020\u4e0a\u306e\u4efb\u610f\u306e div \u30d6\u30ed\u30c3\u30af\u3084\u30d5\u30ec\u30c3\u30af\u30b9\u30dc\u30c3\u30af\u30b9\u3092\u53f3\u30af\u30ea\u30c3\u30af\u3057\u3001\u300c\u30b3\u30f3\u30dd\u30fc\u30cd\u30f3\u30c8\u3092\u4f5c\u6210\u300d\u3092\u9078\u629e\u3057\u307e\u3059"],"Create your first one:":["\u6700\u521d\u306e\u30b3\u30f3\u30dd\u30fc\u30cd\u30f3\u30c8\u3092\u4f5c\u6210\u3057\u307e\u3057\u3087\u3046:"],"Learn more about components":["\u30b3\u30f3\u30dd\u30fc\u30cd\u30f3\u30c8\u306b\u3064\u3044\u3066\u3055\u3089\u306b\u8a73\u3057\u304f"],"With your current role, you cannot create components. Contact an administrator to create one.":["\u73fe\u5728\u306e\u6a29\u9650\u30b0\u30eb\u30fc\u30d7\u3067\u306f\u3001\u30b3\u30f3\u30dd\u30fc\u30cd\u30f3\u30c8\u3092\u4f5c\u6210\u3067\u304d\u307e\u305b\u3093\u3002\u4f5c\u6210\u3059\u308b\u306b\u306f\u3001\u7ba1\u7406\u8005\u306b\u9023\u7d61\u3057\u3066\u304f\u3060\u3055\u3044\u3002"],"Create once, use everywhere.":["\u4e00\u5ea6\u4f5c\u6210\u3059\u308c\u3070\u3001\u3069\u3053\u3067\u3082\u4f7f\u7528\u3067\u304d\u307e\u3059\u3002"],"Components are reusable blocks that sync across your site.":["\u30b3\u30f3\u30dd\u30fc\u30cd\u30f3\u30c8\u3068\u306f\u3001\u30b5\u30a4\u30c8\u5168\u4f53\u3067\u540c\u671f\u3055\u308c\u308b\u518d\u5229\u7528\u53ef\u80fd\u306a\u30d6\u30ed\u30c3\u30af\u306e\u3053\u3068\u3067\u3059\u3002"],"No components yet":["\u307e\u3060\u30b3\u30f3\u30dd\u30fc\u30cd\u30f3\u30c8\u304c\u3042\u308a\u307e\u305b\u3093"],"Can't add this component - components that contain each other can't be nested.":["\u3053\u306e\u30b3\u30f3\u30dd\u30fc\u30cd\u30f3\u30c8\u3092\u8ffd\u52a0\u3067\u304d\u307e\u305b\u3093 - \u4e92\u3044\u3092\u542b\u3080\u30b3\u30f3\u30dd\u30fc\u30cd\u30f3\u30c8\u540c\u58eb\u3092\u30cd\u30b9\u30c8 (\u5165\u308c\u5b50\u306b) \u3059\u308b\u3053\u3068\u306f\u3067\u304d\u307e\u305b\u3093\u3002"],"Edit Component":["\u30b3\u30f3\u30dd\u30fc\u30cd\u30f3\u30c8\u3092\u7de8\u96c6"],"You can wait for them to finish or reach out to coordinate your changes together.":["\u5f7c\u3089\u304c\u5b8c\u4e86\u3059\u308b\u307e\u3067\u5f85\u3064\u3053\u3068\u3082\u3001\u9023\u7d61\u3092\u53d6\u308a\u5408\u3063\u3066\u5909\u66f4\u3092\u8abf\u6574\u3059\u308b\u3053\u3068\u3082\u3067\u304d\u307e\u3059\u3002"],"%s is currently editing this document":["%s \u306f\u73fe\u5728\u3053\u306e\u6587\u66f8\u3092\u7de8\u96c6\u4e2d\u3067\u3059"],"Components":["\u30b3\u30f3\u30dd\u30fc\u30cd\u30f3\u30c8"],"Clear & try again":["\u30af\u30ea\u30a2\u3057\u3066\u3082\u3046\u4e00\u5ea6\u304a\u8a66\u3057\u304f\u3060\u3055\u3044"],"Try something else.":["\u4ed6\u306e\u3053\u3068\u3092\u8a66\u3057\u3066\u304f\u3060\u3055\u3044\u3002"],"Sorry, nothing matched":["\u3059\u307f\u307e\u305b\u3093\u3001\u4e00\u81f4\u3059\u308b\u60c5\u5831\u306f\u898b\u3064\u304b\u308a\u307e\u305b\u3093\u3067\u3057\u305f"],"Upgrade now":["\u4eca\u3059\u3050\u30a2\u30c3\u30d7\u30b0\u30ec\u30fc\u30c9"],"Upgrade Now":["\u4eca\u3059\u3050\u30a2\u30c3\u30d7\u30b0\u30ec\u30fc\u30c9"],"Search":["\u691c\u7d22"],"Update Elementor Pro":["Elementor Pro \u3092\u66f4\u65b0"],"Edit %s":["%s\u3092\u7de8\u96c6"],"Close":["\u9589\u3058\u308b"],"Update Now":["\u4eca\u3059\u3050\u66f4\u65b0"]}},"comment":{"reference":"assets\/js\/packages\/editor-components\/editor-components.js"}}